{
  "expo": {
    "name": "Morf",
    "slug": "morfai",
    "version": "1.6.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "morfai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vanquil.morfai",
      "appleTeamId": "C24TFJT58Y",
      "jsEngine": "hermes",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Morf needs access to your photo library to let you upload a profile picture.",
        "NSLocationWhenInUseUsageDescription": "Morf uses your location to show your country on leaderboards and connect you with nearby lifters.",
        "NSSupportsLiveActivities": true,
        "NSPhotoLibraryAddUsageDescription": "Morf saves your workout recap cards to your photo library when you tap Save."
      },
      "entitlements": {
        "com.apple.security.application-groups": ["group.com.vanquil.morfai"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1A1A1A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.vanquil.morfai",
      "jsEngine": "hermes"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "@bacons/apple-targets",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1A1A1A"
        }
      ],
      "expo-font",
      "expo-audio",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Morf needs access to your photo library to let you upload a profile picture."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Morf uses your location to show your country on leaderboards."
        }
      ],
      "expo-video",
      [
        "expo-notifications",
        {
          "color": "#6366F1"
        }
      ],
      "expo-secure-store",
      "expo-asset",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Morf uses your microphone so you can log sets hands-free by voice.",
          "speechRecognitionPermission": "Morf uses speech recognition to turn your spoken sets into a workout log."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4f7ed05a-985e-4200-a577-ccc419b7ea77"
      }
    },
    "sdkVersion": "54.0.0"
  }
}
